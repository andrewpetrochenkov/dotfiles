{
  "name": "dotfiles-runners",
  "displayName": "Dotfiles Runners",
  "description": "Run current file (Sublime Text builders port)",
  "publisher": "dotfiles",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:dotfiles-runners.run",
    "onCommand:dotfiles-runners.runPython",
    "onCommand:dotfiles-runners.runBash",
    "onCommand:dotfiles-runners.runMake",
    "onCommand:dotfiles-runners.runNode",
    "onCommand:dotfiles-runners.runPhp",
    "onCommand:dotfiles-runners.runSql",
    "onCommand:dotfiles-runners.runHtml",
    "onCommand:dotfiles-runners.runAwk",
    "onCommand:dotfiles-runners.runApplescript",
    "onCommand:dotfiles-runners.runSwift"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dotfiles-runners.run",
        "title": "Run File (auto)"
      },
      {
        "command": "dotfiles-runners.runPython",
        "title": "Run: Python"
      },
      {
        "command": "dotfiles-runners.runBash",
        "title": "Run: Bash"
      },
      {
        "command": "dotfiles-runners.runMake",
        "title": "Run: Makefile"
      },
      {
        "command": "dotfiles-runners.runNode",
        "title": "Run: Node.js"
      },
      {
        "command": "dotfiles-runners.runPhp",
        "title": "Run: PHP"
      },
      {
        "command": "dotfiles-runners.runSql",
        "title": "Run: SQL"
      },
      {
        "command": "dotfiles-runners.runHtml",
        "title": "Run: HTML"
      },
      {
        "command": "dotfiles-runners.runAwk",
        "title": "Run: AWK"
      },
      {
        "command": "dotfiles-runners.runApplescript",
        "title": "Run: AppleScript"
      },
      {
        "command": "dotfiles-runners.runSwift",
        "title": "Run: Swift"
      }
    ]
  }
}
