
# /usr/local/var/postgres
# /opt/homebrew/var/postgres
# PGDATA="/opt/homebrew/var/postgres"
PGUSER=postgres
PGDATA="/Volumes/HDD/var/postgres"
# .psqlrc, default ~/.psqlrc
PSQLRC="$XDG_CONFIG_HOME/.psqlrc"
# .psql_history, default ~/.psql_history
PSQL_HISTORY="$XDG_CACHE_HOME/.psql_history"
PGPASSFILE="$XDG_CONFIG_HOME/.pgpass"
# PGSERVICEFILE="$XDG_CONFIG_HOME/pg/pg_service.conf"
