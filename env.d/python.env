PYTHONIOENCODING="UTF-8"

# PYTHONHOME - Change the location of the standard Python libraries
# PYTHONPATH - Augment the default search path for module files
# .pydistutils.cfg $HOME, ~ works only for certain keys (use /usr/)
# pip install ... --target="$PYTHONPATH"
# PYTHONPATH=

# PYTHONSTARTUP="$PYTHONHOME"/startup.py
# only interactive mode
PYTHONSTARTUP=~/.pythonrc.py

PYTHON_KEYRING_BACKEND=keyring.backends.null.Keyring


