# https://www.gnu.org/s/bash/manual/html_node/Bash-Variables.html

IFS=
BASH_ENV=~/.bashrc
BASH_XTRACEFD=2 # bash 4.1+

# /etc/bashrc_Apple_Terminal
# ~/.bash_sessions_disable or SHELL_SESSION_HISTORY=0
SHELL_SESSION_HISTORY=0 # disable ~/.bash_sessions/

HISTCONTROL=ignoredups:ignorespace
HISTSIZE='32768';
HISTFILESIZE="${HISTSIZE}";
HISTFILE=/tmp/bash_history # /dev/null

PS1="$ "
# PROMPT_COMMAND=update_terminal_cwd
