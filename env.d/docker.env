DOCKER_CONFIG="$XDG_CONFIG_HOME"/.docker
# DOCKER_HOST=unix:///Users/$(whoami)/Library/Containers/com.docker.docker/Data/docker.sock
DOCKER_HOST=unix://$HOME/.docker/run/docker.sock
MACHINE_STORAGE_PATH="$XDG_DATA_HOME"/docker-machine
DOCKER_HOST=unix://$HOME/.docker/run/docker.sock

# buildkitd (daemon), buildx (cli)
DOCKER_BUILDKIT=1
BUILDKIT_DEBUG=1
BUILDKIT_PROGRESS=plain
BUILDKIT_STEP_RETRY=10000
BUILDKIT_STEP_RETRY_DELAY=1
BUILDKIT_INSECURE_REGISTRIES=registry:5000
